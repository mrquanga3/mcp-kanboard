# Kanboard JSON-RPC endpoint. The "/jsonrpc.php" suffix is appended automatically if missing.
KANBOARD_URL=http://localhost/kanboard

# API token. For an Application token (Settings -> API), KANBOARD_USERNAME must be "jsonrpc".
# For a Personal token (My Profile -> Actions -> API), use your login as KANBOARD_USERNAME.
KANBOARD_API_TOKEN=PASTE_TOKEN_HERE
KANBOARD_USERNAME=jsonrpc

# Optional tuning
# KANBOARD_TIMEOUT=30
# KANBOARD_MAX_ATTACHMENT_MB=25
# KANBOARD_VERIFY_SSL=true

# Required when running with --http (claude.ai web).
# The MCP server gates the OAuth login form with this passphrase. Set anything
# you'll remember; you'll type it once in the popup when claude.ai first
# connects, and refresh tokens take care of the rest.
# MCP_PASSPHRASE=type_anything_secret_here

# Optional: dedicated ngrok authtoken for this MCP. Set when you run multiple
# MCPs in parallel on ngrok free plan (1 static domain per account). Use a
# different ngrok account's token here than the one your other MCPs use.
# Falls back to NGROK_AUTHTOKEN, then ngrok's global config.
# KANBOARD_NGROK_AUTHTOKEN=2abc...your_kanboard_account_token

# Optional: explicit static domain to publish under (without https:// prefix).
# Required when KANBOARD_NGROK_AUTHTOKEN belongs to an account that also has
# another agent running -- pass the domain belonging to THIS account to avoid
# ngrok auto-picking the wrong default. Find it in ngrok dashboard -> Domains.
# KANBOARD_NGROK_DOMAIN=chevron-handball-impromptu.ngrok-free.dev
